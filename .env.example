# MollyStaking deploy environment
# Copy this file to `.env` (cp .env.example .env / copy .env.example .env on Windows)
# and fill in your deployer key. .env is gitignored — never committed.

# Your deployer wallet's private key, with 0x prefix.
# Example: DEPLOYER_KEY=0xabc123...
# This wallet pays gas + becomes the contract owner.
DEPLOYER_KEY=

# Monad mainnet RPC (any of these work; pick whichever is reliable)
RPC=https://rpc.monad.xyz
# Alternatives if rpc.monad.xyz is rate-limiting:
# RPC=https://monad-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC=https://attentive-magical-sanctuary.monad-mainnet.quiknode.pro/YOUR_KEY/

# Monadscan API key — from monadscan.com, NOT etherscan.io.
# Register: https://monadscan.com/register
# Then go to your account → API Keys → create one.
# Only needed for the verify step (scripts/verify-only.js).
MONADSCAN_API_KEY=
