# Deployer wallet — must hold MON for gas
# Use the standard Molly deployer wallet:
PRIVATE_KEY=

# Monad RPC URLs (defaults work, override for Alchemy if you want speed)
MONAD_RPC=https://rpc.monad.xyz
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz

# Etherscan V2 unified API key — same key used for MollyStaking verification
# Get one at https://etherscan.io/myapikey (NOT bscscan/monadscan)
ETHERSCAN_API_KEY=
