{
  "name": "molly-poker",
  "version": "0.1.0",
  "private": true,
  "description": "Texas Hold'em poker contract for the Molly ecosystem on Monad. 70/20/10 pot split (winner/burn/dev). Forked from dxganta/poker-solidity.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network monadTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network monad",
    "verify:testnet": "hardhat run scripts/verify.js --network monadTestnet",
    "verify:mainnet": "hardhat run scripts/verify.js --network monad"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.10",
    "dotenv": "^16.4.5"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  }
}
