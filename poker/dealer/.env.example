# Monad mainnet RPC — recommend QuickNode (public rpc is rate-limited)
MONAD_RPC=https://attentive-magical-sanctuary.monad-mainnet.quiknode.pro/<your-key>/

# Dealer private key — owns MollyPoker, signs dealCards/dealCommunityCards/showdown
# v1: same as the deployer wallet (0xB9d4...e467f)
# v2: create a dedicated dealer wallet + transferOwnership for security isolation
DEALER_PRIVATE_KEY=<dealer private key, NO 0x prefix>

# Deployed MollyPoker address
MOLLY_POKER_ADDRESS=0x61bE14a42E6a233120aaec95658b5187AE99b814

# WebSocket port
PORT=4001

# Logging level: debug, info, warn, error
LOG_LEVEL=info
