# Monad mainnet HTTP RPC — used for tx submission + read calls
# QuickNode recommended (public rpc is rate-limited)
MONAD_RPC=https://attentive-magical-sanctuary.monad-mainnet.quiknode.pro/<your-key>/

# Optional WebSocket RPC for chain event subscriptions (sub-second latency
# vs ~2-12s for HTTP polling). Highly recommended for production.
# Same QuickNode endpoint, just wss:// scheme.
MONAD_RPC_WSS=wss://attentive-magical-sanctuary.monad-mainnet.quiknode.pro/<your-key>/

# Dealer private key — owns MollyPoker, signs dealCards/dealCommunityCards/showdown
# v1: same as the deployer wallet (0xB9d4...e467f)
# v2: create a dedicated dealer wallet + transferOwnership for security isolation
DEALER_PRIVATE_KEY=<dealer private key, NO 0x prefix>

# Deployed MollyPoker address
MOLLY_POKER_ADDRESS=0x61bE14a42E6a233120aaec95658b5187AE99b814

# WebSocket port for the dealer to listen on (clients connect here)
PORT=4001

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Set to 1 if running behind a reverse proxy (nginx) — trusts x-forwarded-for header
# DEALER_TRUST_PROXY=1
