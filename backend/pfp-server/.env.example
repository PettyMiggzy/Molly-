# Server port (alongside monpad-server on 3001)
PORT=3002

# QuickNode Monad mainnet endpoint — replace with your actual URL
# Pattern: https://<endpoint-name>.monad-mainnet.quiknode.pro/<key>/
QUICKNODE_RPC=https://attentive-magical-sanctuary.monad-mainnet.quiknode.pro/YOUR_KEY_HERE/

# Where to write image files (relative to project root or absolute path)
PFP_DIR=./pfps

# 100K MOLLY in wei = 100000 * 1e18
HOLD_REQUIRED_WEI=100000000000000000000000
